# Copy to .env and fill in. Never commit .env.

PORT=5001

# Supabase (Dashboard → Settings → API)
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=your_anon_key

# Server-side / scripts only — never expose in Next.js client code
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# DB migrations (npm run db:apply-*): do not put the DB password in this file. In your shell:
#   export SUPABASE_DB_PASSWORD='…'
# Or use DATABASE_URL from Dashboard → Database → Session pooler (URL-encode @ in password as %40).

# OpenAI — primary intake classifier (required by Backend/config/openai.ts at startup)
OPENAI_API_KEY=your_openai_api_key

# --- AWS (optional) — Bedrock fallback / comparison; S3 for optional voice asset storage ---
# Bedrock: enable model access in the Bedrock console. Use us-east-1 for typical Anthropic models.
# On Elastic Beanstalk with an instance role, set BEDROCK_ENABLED=true (no static keys required).
# BEDROCK_ENABLED=true
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# Required for temporary (ASIA…) keys — do not use a line starting with "export" in .env
# AWS_SESSION_TOKEN=
# AWS_REGION=us-east-1
# GET /api/ai/bedrock-test uses BEDROCK_MODEL_ID (classifier may still use BEDROCK_CLASSIFY_MODEL_ID)
# BEDROCK_MODEL_ID=anthropic.claude-3-haiku-20240307-v1:0
# Optional: BEDROCK_CLASSIFY_MODEL_ID=anthropic.claude-3-haiku-20240307-v1:0
# Optional parallel cross-check vs OpenAI (appends note to reasoning_summary when labels disagree):
# BEDROCK_COMPARE_INTAKE=true
#
# S3 optional uploads (e.g. ElevenLabs MP3 from generateVoiceMessage — uploads when bucket is set unless S3_UPLOAD_VOICE_TTS=false)
# S3_BUCKET_NAME=your-bucket
# (legacy alias) S3_AUDIO_BUCKET=
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# Optional for temporary session keys:
# AWS_SESSION_TOKEN=
# AWS_REGION=us-east-1
# S3_AUDIO_PREFIX=voice
# S3_PUBLIC_BASE_URL=https://your-cdn.example.com
# S3_UPLOAD_VOICE_TTS=true

# Hugging Face Inference API — optional zero-shot helper (facebook/bart-large-mnli or distilbart)
# If unset, intake skips HF and uses OpenAI only.
HF_API_KEY=
# Optional override (default: valhalla/distilbart-mnli-12-3)
# HF_ZERO_SHOT_MODEL=facebook/bart-large-mnli

# Google Maps: enable "Places API" for this key. Used by Backend intake (nearby food).
# Optional — if unset, intake uses Supabase resources only.
GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# Voice / telephony (optional — reservation API still succeeds without these)
# DEMO_MODE=true simulates outbound confirmation calls and logs payloads — set false for real rings.
DEMO_MODE=false
#
# Real calls: seeker enters their mobile on Request → Reserve (E.164, not TWILIO_PHONE_NUMBER).
# Provider ring order: profiles.phone_number → PROVIDER_ALERT_PHONE → TWILIO_TEST_TO.
#
# Your personal cell for scripts/tests (E.164). Must differ from TWILIO_PHONE_NUMBER. Trial: verify in Twilio.
# TWILIO_TEST_TO=+15551234567
ELEVENLABS_API_KEY=
# Optional TTS overrides
# ELEVENLABS_VOICE_ID=
# ELEVENLABS_MODEL_ID=
# Required for real calls (even if you use TWILIO_API_KEY_SID).
TWILIO_ACCOUNT_SID=
# Main Auth Token OR, with TWILIO_API_KEY_SID, the API Key secret (not the main token).
TWILIO_AUTH_TOKEN=
# Optional — if you use a standard API key (SK…) instead of main Auth Token:
# TWILIO_API_KEY_SID=
# Your Twilio voice/SMS number (caller ID). Cannot be the same as the phone you are calling.
TWILIO_PHONE_NUMBER=
# Optional fallback when the listing provider has no profiles.phone_number (E.164, not TWILIO_PHONE_NUMBER).
# PROVIDER_ALERT_PHONE=+15559876543

# --- Frontend (Next.js) — create Frontend/.env.local with the same values as above ---
# NEXT_PUBLIC_SUPABASE_URL=$SUPABASE_URL
# NEXT_PUBLIC_SUPABASE_ANON_KEY=$SUPABASE_ANON_KEY
# NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=$GOOGLE_MAPS_API_KEY
# NEXT_PUBLIC_API_URL=http://localhost:5001
